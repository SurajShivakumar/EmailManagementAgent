# InsForge (Dashboard → API keys, or CLI: npx @insforge/cli metadata --json)
NEXT_PUBLIC_INSFORGE_URL=https://YOUR_APPKEY.us-east.insforge.app
INSFORGE_ANON_KEY=

# Optional: defaults to first row in `users` when unset
DEFAULT_USER_ID=

# Optional: override InsForge AI model (project must enable it)
INSFORGE_AI_MODEL=anthropic/claude-sonnet-4.5

# Gmail OAuth — Google Cloud Console → APIs & Services → Credentials
# 1) Enable Gmail API for the project
# 2) Create OAuth client ID type "Web application"
# 3) Authorized redirect URI must match GMAIL_REDIRECT_URI exactly (your dev URL + /api/auth/gmail/callback)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback
